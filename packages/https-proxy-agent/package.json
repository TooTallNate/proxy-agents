{
  "name": "https-proxy-agent",
  "version": "7.0.6",
  "type": "module",
  "description": "An HTTP(s) proxy `http.Agent` implementation for HTTPS",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest --exclude test/e2e.test.ts",
    "test-e2e": "vitest run test/e2e.test.ts",
    "lint": "eslint --ext .ts",
    "pack": "node ../../scripts/pack.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TooTallNate/proxy-agents.git",
    "directory": "packages/https-proxy-agent"
  },
  "keywords": [
    "https",
    "proxy",
    "endpoint",
    "agent"
  ],
  "author": "Nathan Rajlich <nathan@tootallnate.net> (http://n8.io/)",
  "license": "MIT",
  "dependencies": {
    "agent-base": "workspace:*",
    "debug": "catalog:"
  },
  "devDependencies": {
    "@types/async-retry": "catalog:",
    "@types/debug": "catalog:",
    "@types/node": "catalog:",
    "async-listen": "catalog:",
    "async-retry": "catalog:",
    "proxy": "workspace:*",
    "tsconfig": "workspace:*",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">= 14"
  }
}
