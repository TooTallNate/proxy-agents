{
  "name": "pac-proxy-agent",
  "version": "9.0.0",
  "type": "module",
  "description": "A PAC file proxy `http.Agent` implementation for HTTP",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint --ext .ts",
