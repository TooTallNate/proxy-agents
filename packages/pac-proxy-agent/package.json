    "pac-resolver": "workspace:*",
    "quickjs-wasi": "catalog:",
    "socks-proxy-agent": "workspace:*"
  },
  "devDependencies": {
    "@types/debug": "catalog:",
    "@types/node": "catalog:",
    "async-listen": "catalog:",
    "proxy": "workspace:*",
    "socksv5": "catalog:",
